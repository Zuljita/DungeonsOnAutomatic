{
  "name": "dungeons-on-automatic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "doa": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "doa": "tsx src/cli/index.ts",
    "format": "prettier --write .",
    "gui": "pnpm --filter @doa/gui dev",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "gui:build": "pnpm --filter @doa/gui build",
    "gui:preview": "pnpm --filter @doa/gui preview --port 3000"
  },
  "dependencies": {
    "@panzoom/panzoom": "^4.6.0",
    "@types/rbush": "^4.0.0",
    "commander": "^12.1.0",
    "delaunator": "^5.0.1",
    "pathfinding": "^0.4.18",
    "pdfkit": "^0.17.1",
    "picocolors": "^1.1.1",
    "rbush": "^4.0.1",
    "semver": "^7.5.4",
    "svg-to-pdfkit": "^0.1.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/delaunator": "^5.0.3",
    "@types/node": "^22.5.1",
    "@types/pathfinding": "^0.1.0",
    "@types/pdfkit": "^0.17.2",
    "@types/semver": "^7.7.0",
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.1.0",
    "eslint": "^9.8.0",
    "playwright": "^1.54.2",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "workspaces": [
    "apps/*"
  ]
}
